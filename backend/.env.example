# Không điền bí mật thật vào file này.
# Bí mật thật được nhập trong Railway Variables.

# ===== Bảo mật =====
JWT_SECRET=
DEVICE_API_KEY=

# ===== PostgreSQL / Supabase =====
DATABASE_URL=

# ===== Gmail gửi OTP =====
EMAIL_USER=
EMAIL_APP_PASSWORD=

# ===== OTP =====
OTP_LENGTH=6
OTP_EXPIRE_HOURS=48

# ===== Chống spam =====
SHIPPER_MAX_ORDERS=5
SHIPPER_WINDOW_MINUTES=60
SHIPPER_STRIKE_LIMIT=3
SHIPPER_BLOCK_MINUTES=120
DOOR_OPEN_TIMEOUT_SECONDS=60

# ===== Môi trường =====
NODE_ENV=production