# ===== Cấu hình chung =====
PORT=3000
JWT_SECRET=doi-chuoi-bi-mat-nay-truoc-khi-chay-that
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# API key mà thiết bị ESP32 phải gửi kèm khi gọi API (đặt trong header X-Device-Key)
DEVICE_API_KEY=doi-khoa-thiet-bi-nay

# ===== Cấu hình OTP =====
OTP_LENGTH=6
OTP_EXPIRE_HOURS=48

# ===== Cấu hình chống spam / chống phá =====
# Số đơn tối đa 1 SĐT shipper được tạo trong khoảng thời gian dưới đây
SHIPPER_MAX_ORDERS=5
SHIPPER_WINDOW_MINUTES=60
# Số lần mở tủ nhưng không đặt hàng trước khi khóa tạm SĐT shipper
SHIPPER_STRIKE_LIMIT=3
# Thời gian khóa tạm SĐT shipper (phút)
SHIPPER_BLOCK_MINUTES=120
# Số giây cửa được phép mở trước khi coi là quá hạn / cảnh báo
DOOR_OPEN_TIMEOUT_SECONDS=60

# ===== Cấu hình gửi SMS =====
# console = chỉ log ra màn hình (dùng để test, KHÔNG gửi SMS thật)
# esms = eSMS.vn (nhà cung cấp SMS phổ biến tại VN)
# twilio = Twilio (quốc tế)
SMS_PROVIDER=console

# --- Nếu dùng eSMS.vn ---
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=SmartLocker

# --- Nếu dùng Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
